  "markdown-pdf.headerTemplate": "<div style=\"font-size: 9px; margin-left: 1cm; margin-right: 1cm; text-align: center; width: 100%;\"><span class='title'></span></div>",
  "markdown-pdf.footerTemplate": "<div style=\"font-size: 9px; margin-left: 1cm; margin-right: 1cm; text-align: center; width: 100%;\"><span class='pageNumber'></span></div>",
  "markdown-pdf.format": "A4",
  "markdown-pdf.margin.top": "2.54cm",
  "markdown-pdf.margin.bottom": "2.54cm",
  "markdown-pdf.margin.left": "2.54cm",
  "markdown-pdf.margin.right": "2.54cm",
  "markdown-pdf.output.directory": "pdf"
}
